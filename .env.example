# Langfuse connection.
# Keep real keys out of git and set them in your shell or a local .env loader.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://langfuse.example.com

# Wind required fields. These values are attached to every observation/resource.
WIND_PRODUCT_NAME=demo
WIND_APP_NAME=flask-cross-process-demo
WIND_APP_CLASS_ID=wind-demo-app
WIND_APP_VERSION=0.1.0
WIND_APP_ENVIRONMENT=dev

# Optional Langfuse client tuning.
LANGFUSE_SAMPLE_RATE=1.0
LANGFUSE_TIMEOUT=10
LANGFUSE_FLUSH_AT=20
LANGFUSE_FLUSH_INTERVAL=5
LANGFUSE_DEBUG=false

# Flask settings.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
